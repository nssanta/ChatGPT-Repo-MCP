[Unit]
Description=chatrepo-mcp
After=network.target

[Service]
Type=simple
User=chatrepo
Group=chatrepo
WorkingDirectory=/opt/chatrepo-mcp
EnvironmentFile=/opt/chatrepo-mcp/.env
ExecStart=/opt/chatrepo-mcp/.venv/bin/python -m chatrepo_mcp
Restart=always
RestartSec=3

# Basic hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
