APP_NAME=chatrepo-mcp
HOST=127.0.0.1
PORT=8000
TRANSPORT=streamable-http

# Absolute path to the ONE repository this server may inspect.
PROJECT_ROOT=/opt/myproject

# Read limits
MAX_FILE_BYTES=262144
MAX_RESPONSE_CHARS=40000
MAX_READ_FILES=8
MAX_SEARCH_RESULTS=100
MAX_TREE_ENTRIES=500
MAX_DIFF_BYTES=131072
MAX_LOG_COMMITS=50

# Timeouts (seconds)
SUBPROCESS_TIMEOUT=15

# Sensitive file patterns blocked from filesystem reads.
# Comma-separated glob patterns, matched against repo-relative POSIX paths.
BLOCKED_GLOBS=.env,.env.*,*.pem,*.key,*.p12,*.pfx,**/.git/**,**/.venv/**,**/node_modules/**

# Include hidden files in listing/search by default? Usually false.
ALLOW_HIDDEN_DEFAULT=false
